---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import InquiryWidget from '../components/InquiryWidget.astro';
import About from '../components/About.astro';
import Amenities from '../components/Amenities.astro';
import Accommodations from '../components/Accommodations.astro';
import Rates from '../components/Rates.astro';
import Policies from '../components/Policies.astro';
import Location from '../components/Location.astro';
import SunsetMoment from '../components/SunsetMoment.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <main>
    <Hero />
    <InquiryWidget />
    <About />
    <Amenities />
    <Accommodations />
    <Rates />
    <Policies />
    <Location />
    <SunsetMoment />
  </main>
  <Footer />
</BaseLayout>
