<section class="relative py-28 md:py-36">
  <div class="max-w-7xl mx-auto px-5 md:px-10 grid md:grid-cols-12 gap-10 md:gap-16 items-center">

    <!-- Copy -->
    <div class="md:col-span-5 reveal">
      <div class="eyebrow text-sunset-500 mb-5">About the Inn</div>
      <h2 class="text-[36px] md:text-[52px] leading-[1.02] text-navy">
        Family-owned,<br />family-run —<br />
        <span class="italic font-light text-gulf-500">three trademarks.</span>
      </h2>
      <div class="hairline mt-9 mb-9"></div>
      <p class="text-[15.5px] leading-[1.75] text-navy/75 max-w-md">
        We are a family-owned and operated motel where cleanliness, our guests' comfort, and a friendly atmosphere are our only trademarks. The Great Heron Inn sits directly on the Gulf — the ideal place to enjoy everything the Florida Suncoast has to offer. Quality museums, golf courses, major-league sports, and the popular theme parks are all just a short drive away.
      </p>
      <div class="mt-8 flex items-center gap-3 text-[13px] text-navy/65">
        <!-- award icon -->
        <svg class="w-4 h-4 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        Featured in Frommer's Travel Guide
      </div>
    </div>

    <!-- Photo collage -->
    <div class="md:col-span-7 reveal">
      <div class="grid grid-cols-12 gap-4 md:gap-5">
        <div class="col-span-8 aspect-[4/5] rounded-md overflow-hidden">
          <img src="/assets/photos/heron-pool.jpg" alt="A great heron beside the pool at Great Heron Inn" class="w-full h-full object-cover" />
        </div>
        <div class="col-span-4 flex flex-col gap-4 md:gap-5">
          <div class="aspect-square rounded-md overflow-hidden">
            <img src="/assets/photos/pool-day.jpg" alt="The heated pool at Great Heron Inn" class="w-full h-full object-cover" />
          </div>
          <div class="flex-1 min-h-[140px] rounded-md overflow-hidden">
            <img src="/assets/photos/sunset-sand.jpg" alt="Golden sunset reflection on the sand at Indian Rocks Beach" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
