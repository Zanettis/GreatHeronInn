---
---

<section id="top" class="relative pt-[80px]">
  <div class="relative h-[88vh] min-h-[640px] w-full overflow-hidden">
    <!-- Ken-burns image -->
    <div class="absolute inset-0 drift">
      <img
        src="/assets/photos/hero-beachfront.webp"
        alt="Great Heron Inn beachfront facade"
        class="w-full h-full object-cover"
        fetchpriority="high"
      />
    </div>
    <!-- Gradients -->
    <div class="absolute inset-0 bg-gradient-to-b from-navy-deep/55 via-navy-deep/25 to-navy-deep/70"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy-deep/40 via-transparent to-transparent"></div>

    <!-- Copy -->
    <div class="relative h-full max-w-7xl mx-auto px-5 md:px-10 flex flex-col justify-end pb-24 md:pb-28">
      <div class="max-w-2xl text-sand-50">
        <div class="eyebrow text-sand-100/80 mb-5 flex items-center gap-3">
          <span class="inline-block w-6 h-px bg-sand-100/60"></span>
          Indian Rocks Beach · Florida
        </div>
        <h1 class="serif text-[44px] sm:text-[64px] md:text-[84px] leading-[0.95] tracking-tight">
          Directly on the<br />
          <span class="italic font-light text-sand-100">beautiful Gulf</span> of Mexico.
        </h1>
        <p class="mt-7 text-[16px] md:text-[17px] leading-relaxed text-sand-100/90 max-w-xl">
          A family-owned inn on Indian Rocks Beach, where cleanliness, comfort, and a friendly welcome have been our trademarks for decades.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a href="#book" class="btn-primary inline-flex items-center gap-2 px-5 py-3 text-[14px] rounded-full font-medium">
            Check Availability
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#stay" class="inline-flex items-center gap-2 px-5 py-3 text-[14px] rounded-full font-medium text-sand-50 border border-sand-50/40 hover:bg-sand-50/10 transition-colors">
            See the rooms
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-3 text-sand-50/80 text-[11px] eyebrow">
      <span class="w-px h-6 bg-sand-50/40"></span>
      Scroll
      <span class="w-px h-6 bg-sand-50/40"></span>
    </div>
  </div>
</section>
