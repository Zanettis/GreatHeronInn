---
---

<section class="relative py-24 md:py-28 bg-gulf-50/60">
  <div class="max-w-7xl mx-auto px-5 md:px-10">

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14 reveal">
      <div>
        <div class="eyebrow text-sunset-500 mb-3">Amenities &amp; facilities</div>
        <h2 class="text-[32px] md:text-[44px] leading-[1.05] text-navy max-w-xl">
          Everything you actually need.<br />
          <span class="italic font-light text-gulf-500">Nothing you don't.</span>
        </h2>
      </div>
      <p class="text-[14.5px] leading-relaxed text-navy/70 max-w-sm">
        Days at the pool, evenings at the dock, mornings on some of Florida's cleanest beaches.
      </p>
    </div>

    <ul class="grid grid-cols-2 md:grid-cols-3 gap-px bg-navy/[.08] border border-navy/[.08] rounded-2xl overflow-hidden reveal">

      <li class="bg-sand-50 p-7 md:p-8">
        <!-- waves -->
        <svg class="w-6 h-6 text-sunset-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6c.6.5 1.2 1 2.5 1C7 7 7 5 9.5 5c2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2"/><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2"/></svg>
        <h3 class="serif text-[20px] mt-5 text-navy">Heated Pool</h3>
        <p class="mt-2 text-[13.5px] text-navy/65 leading-relaxed">Warmed year-round, with chaises facing the Gulf.</p>
      </li>

      <li class="bg-sand-50 p-7 md:p-8">
        <!-- sun -->
        <svg class="w-6 h-6 text-sunset-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
        <h3 class="serif text-[20px] mt-5 text-navy">Right on the Beach</h3>
        <p class="mt-2 text-[13.5px] text-navy/65 leading-relaxed">Directly on some of Florida's cleanest white-sand beaches.</p>
      </li>

      <li class="bg-sand-50 p-7 md:p-8">
        <!-- fish -->
        <svg class="w-6 h-6 text-sunset-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 12c.94-3.46 4.94-6 8.5-6 3.56 0 6.06 2.54 7 6-.94 3.47-3.44 6-7 6s-7.56-2.53-8.5-6Z"/><path d="M18 12v.5"/><path d="M16 17.93a9.77 9.77 0 0 1 0-11.86"/><path d="M7 10.67C7 8 5.58 5.97 2.73 5.5c-1 3.98-.41 6.44 2.27 7.5L7 13l-.18 1.5C10.59 20 13 21 16 21c-1.41-2.07-2-3.67-2-6.1"/><path d="m11.45 9.5-3.2 1.1"/><path d="m12.44 12.6-3.2 1.1"/></svg>
        <h3 class="serif text-[20px] mt-5 text-navy">Private Dock</h3>
        <p class="mt-2 text-[13.5px] text-navy/65 leading-relaxed">On the Inland Coastal Waterway — great for fishing or just watching the herons fish.</p>
      </li>

      <li class="bg-sand-50 p-7 md:p-8">
        <!-- bed-double -->
        <svg class="w-6 h-6 text-sunset-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20v-8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8"/><path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4"/><path d="M12 10v4"/><path d="M2 18h20"/></svg>
        <h3 class="serif text-[20px] mt-5 text-navy">Daily Maid Service</h3>
        <p class="mt-2 text-[13.5px] text-navy/65 leading-relaxed">Fresh linens and a tidy room while you're out exploring.</p>
      </li>

      <li class="bg-sand-50 p-7 md:p-8">
        <!-- wind -->
        <svg class="w-6 h-6 text-sunset-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>
        <h3 class="serif text-[20px] mt-5 text-navy">Central Air &amp; Heat</h3>
        <p class="mt-2 text-[13.5px] text-navy/65 leading-relaxed">Individually controlled in every suite, set just how you like it.</p>
      </li>

      <li class="bg-sand-50 p-7 md:p-8">
        <!-- tv -->
        <svg class="w-6 h-6 text-sunset-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="15" x="2" y="7" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/></svg>
        <h3 class="serif text-[20px] mt-5 text-navy">Cable TV &amp; Phone</h3>
        <p class="mt-2 text-[13.5px] text-navy/65 leading-relaxed">Cable television and direct-dial telephones in every room.</p>
      </li>

    </ul>
  </div>
</section>
