---
---

<section id="beach" class="relative bg-navy-deep text-sand-50 overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="/assets/photos/property-sunset.jpg"
      alt="Sunset over Great Heron Inn pool deck and the Gulf of Mexico"
      class="w-full h-full object-cover opacity-60"
    />
  </div>
  <div class="absolute inset-0 bg-gradient-to-r from-navy-deep via-navy-deep/85 to-navy-deep/40"></div>

  <div class="relative max-w-7xl mx-auto px-5 md:px-10 py-20 md:py-36 grid md:grid-cols-12 gap-10">

    <div class="md:col-span-7 reveal">
      <div class="eyebrow text-sunset-400 mb-5">Directly on the Gulf of Mexico</div>
      <h2 class="text-[36px] md:text-[56px] leading-[1.02] max-w-2xl">
        Indian Rocks Beach — quiet sand, a slow tide, and the Florida Suncoast at your doorstep.
      </h2>
      <p class="mt-8 text-[15px] leading-[1.8] text-sand-100/85 max-w-xl">
        We're between Clearwater and St. Pete, on Pinellas County's quiet side. Tampa International is about half an hour away. Most of our guests come back year after year — and rarely leave the sand for long.
      </p>
    </div>

    <div class="md:col-span-5 md:pl-10 md:border-l border-sand-50/15 reveal">
      <ul class="space-y-6">
        <li class="flex items-start gap-4">
          <svg class="w-5 h-5 mt-1 text-sunset-400 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/></svg>
          <div>
            <div class="serif text-[18px]">Museums &amp; galleries</div>
            <div class="text-[13.5px] text-sand-100/70 mt-1">A short drive — Dalí, MFA, Chihuly.</div>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <svg class="w-5 h-5 mt-1 text-sunset-400 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="14.5 4 18 4 18 7.5"/><path d="m21 3-7 7"/><path d="M10.5 20.5 4 14l1.5-1.5"/><path d="M5 14v5h5"/><path d="M2.5 21.5a4 4 0 0 0 5.66 0L20 9.66a4 4 0 0 0 0-5.66 4 4 0 0 0-5.66 0L2.5 15.84a4 4 0 0 0 0 5.66z"/></svg>
          <div>
            <div class="serif text-[18px]">Golf courses</div>
            <div class="text-[13.5px] text-sand-100/70 mt-1">More than a dozen within easy reach.</div>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <svg class="w-5 h-5 mt-1 text-sunset-400 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          <div>
            <div class="serif text-[18px]">Major-league sports</div>
            <div class="text-[13.5px] text-sand-100/70 mt-1">Rays, Bucs, Lightning — Tampa Bay area.</div>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <svg class="w-5 h-5 mt-1 text-sunset-400 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          <div>
            <div class="serif text-[18px]">Theme parks</div>
            <div class="text-[13.5px] text-sand-100/70 mt-1">All of Orlando's favorites — an easy day trip.</div>
          </div>
        </li>
      </ul>
    </div>

  </div>
</section>
