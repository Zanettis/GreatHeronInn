---
import { SITE } from '../config';
---

<div id="book" class="relative max-w-6xl mx-auto px-5 md:px-10 -mt-12 md:-mt-14 z-10">
  <form id="inquiryForm" class="bg-sand-50 shadow-soft rounded-2xl border border-navy/[.06] overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-[1.1fr_1.1fr_1fr_1.1fr_auto]">
      <label class="field p-4 md:p-5 block min-h-[72px]">
        <span class="eyebrow text-gulf-500">Arrive</span>
        <input type="date" id="arriveInput" name="arrive" class="block mt-1.5 w-full bg-transparent text-[15px] text-navy font-medium outline-none min-h-[36px]" />
      </label>
      <label class="field p-4 md:p-5 block min-h-[72px]">
        <span class="eyebrow text-gulf-500">Depart</span>
        <input type="date" id="departInput" name="depart" class="block mt-1.5 w-full bg-transparent text-[15px] text-navy font-medium outline-none min-h-[36px]" />
      </label>
      <label class="field p-4 md:p-5 block min-h-[72px]">
        <span class="eyebrow text-gulf-500">Guests</span>
        <select name="guests" class="block mt-1.5 w-full bg-transparent text-[15px] text-navy font-medium outline-none appearance-none min-h-[36px]">
          <option>2 adults</option>
          <option>2 adults · 1 child</option>
          <option>2 adults · 2 children</option>
          <option>3 adults</option>
          <option>4 adults</option>
          <option>5 adults</option>
          <option>6 adults</option>
        </select>
      </label>
      <label class="field p-4 md:p-5 block min-h-[72px]">
        <span class="eyebrow text-gulf-500">Suite</span>
        <select name="suite" class="block mt-1.5 w-full bg-transparent text-[15px] text-navy font-medium outline-none appearance-none min-h-[36px]">
          <option>1-Bedroom Suite · Poolside</option>
          <option>1-Bedroom Suite · Gulf Front</option>
          <option>3-Bedroom Condo Apartment</option>
        </select>
      </label>
      <div class="p-3 flex items-stretch md:items-center">
        <button type="submit" id="inquiryBtn" class="btn-primary inline-flex items-center justify-center gap-2 w-full md:w-auto px-7 py-3.5 rounded-xl font-medium text-[14px]">
          Request Availability
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 border-t border-navy/[.06]">
      <label class="field p-4 block min-h-[72px]">
        <span class="eyebrow text-gulf-500">Your Name</span>
        <input type="text" id="guestName" placeholder="Jane Smith" class="block mt-1.5 w-full bg-transparent text-[15px] text-navy font-medium outline-none placeholder:text-navy/30 min-h-[36px]" />
      </label>
      <label class="field p-4 block min-h-[72px]">
        <span class="eyebrow text-gulf-500">Phone Number</span>
        <input type="tel" id="guestPhone" placeholder="(555) 000-0000" class="block mt-1.5 w-full bg-transparent text-[15px] text-navy font-medium outline-none placeholder:text-navy/30 min-h-[36px]" />
      </label>
      <label class="field p-4 block min-h-[72px]">
        <span class="eyebrow text-gulf-500">Your Email</span>
        <input type="email" id="guestEmail" placeholder="you@example.com" class="block mt-1.5 w-full bg-transparent text-[15px] text-navy font-medium outline-none placeholder:text-navy/30 min-h-[36px]" />
      </label>
    </div>
  </form>

  <p id="inquiryMsg" class="hidden mt-3 ml-2 text-[13px]"></p>
  <p class="mt-3 ml-2 text-[12px] text-navy/55">
    We answer every inquiry personally — usually within a few hours. Or call
    <a href={`tel:${SITE.phoneTel}`} class="text-navy underline-grow">{SITE.phone}</a>.
  </p>
</div>

<script>
  const form      = document.getElementById('inquiryForm') as HTMLFormElement;
  const msg       = document.getElementById('inquiryMsg')!;
  const btn       = document.getElementById('inquiryBtn')!;
  const arriveEl  = document.getElementById('arriveInput') as HTMLInputElement;
  const departEl  = document.getElementById('departInput') as HTMLInputElement;

  const fmt = (d: Date) => d.toISOString().slice(0, 10);

  function addDays(d: Date, n: number): Date {
    const r = new Date(d);
    r.setDate(r.getDate() + n);
    return r;
  }

  // Minimum check-in is tomorrow
  const today    = new Date();
  const tomorrow = addDays(today, 1);

  arriveEl.min   = fmt(tomorrow);
  arriveEl.value = fmt(tomorrow);
  departEl.min   = fmt(addDays(tomorrow, 3));
  departEl.value = fmt(addDays(tomorrow, 3));

  arriveEl.addEventListener('change', () => {
    const arrive = new Date(arriveEl.value + 'T00:00:00');
    const minDepart = addDays(arrive, 3);
    departEl.min = fmt(minDepart);
    if (departEl.value && new Date(departEl.value + 'T00:00:00') < minDepart) {
      departEl.value = fmt(minDepart);
    }
  });

  function showError(text: string) {
    msg.textContent = text;
    msg.className = 'mt-3 ml-2 text-[13px] text-amber-700';
  }

  function showSuccess(text: string) {
    msg.textContent = text;
    msg.className = 'mt-3 ml-2 text-[13px] text-gulf-700';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name   = (document.getElementById('guestName')  as HTMLInputElement).value.trim();
    const phone  = (document.getElementById('guestPhone') as HTMLInputElement).value.trim();
    const email  = (document.getElementById('guestEmail') as HTMLInputElement).value.trim();
    const arrive = arriveEl.value;
    const depart = departEl.value;
    const guests = (form.elements as any)['guests'].value;
    const suite  = (form.elements as any)['suite'].value;

    // Date validation
    if (arrive) {
      const arriveDate = new Date(arrive + 'T00:00:00');
      if (arriveDate < tomorrow) {
        showError('Check-in must be at least tomorrow.');
        arriveEl.focus();
        return;
      }
      if (depart) {
        const departDate = new Date(depart + 'T00:00:00');
        const nights = (departDate.getTime() - arriveDate.getTime()) / 86400000;
        if (nights < 3) {
          showError('Minimum stay is 3 nights.');
          departEl.focus();
          return;
        }
      }
    }

    if (!email) {
      showError('Please enter your email address.');
      (document.getElementById('guestEmail') as HTMLInputElement).focus();
      return;
    }

    btn.textContent = 'Sending…';
    btn.setAttribute('disabled', 'true');
    msg.className = 'hidden';

    try {
      const res = await fetch('/api/inquiry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, phone, email, arrive, depart, guests, suite }),
      });

      if (res.ok) {
        showSuccess(`Thank you${name ? ', ' + name : ''}! We'll personally check availability for ${arrive} → ${depart} (${guests}, ${suite}) and reply to ${email} within a few hours.`);
        form.reset();
        arriveEl.value = fmt(tomorrow);
        departEl.value = fmt(addDays(tomorrow, 3));
        departEl.min   = fmt(addDays(tomorrow, 3));
      } else {
        const body = await res.json().catch(() => ({}));
        showError(body.error || 'Something went wrong — please call us directly at (727) 595-2589.');
      }
    } catch {
      showError('Could not send — please call us at (727) 595-2589.');
    } finally {
      btn.textContent = 'Request Availability';
      btn.removeAttribute('disabled');
    }
  });
</script>
