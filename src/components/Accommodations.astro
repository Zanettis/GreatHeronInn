---
import { SITE } from '../config';
---

<section id="stay" class="relative py-28 md:py-36">
  <div class="max-w-7xl mx-auto px-5 md:px-10">

    <div class="grid md:grid-cols-12 gap-10 items-end mb-14 reveal">
      <div class="md:col-span-7">
        <div class="eyebrow text-sunset-500 mb-3">Accommodations</div>
        <h2 class="text-[36px] md:text-[52px] leading-[1.02] text-navy">
          Two ways to stay,<br />
          <span class="italic font-light text-gulf-500">both facing the water.</span>
        </h2>
      </div>
      <div class="md:col-span-5">
        <p class="text-[15px] leading-[1.75] text-navy/70">
          A roomy one-bedroom suite for couples and small families, and a full three-bedroom condo for the whole crew. Every door opens to the same view.
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6 md:gap-8">

      <!-- 1BR Suite -->
      <article class="room-card bg-sand-50 rounded-2xl overflow-hidden border border-navy/[.06] shadow-card reveal">
        <div class="aspect-[16/10] overflow-hidden">
          <div class="room-img w-full h-full">
            <img src="/assets/photos/suite-poolside.jpg" alt="1-bedroom suite poolside view" class="w-full h-full object-cover" />
          </div>
        </div>
        <div class="p-8 md:p-10">
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <h3 class="serif text-[28px] text-navy">1-Bedroom Apartment Suite</h3>
            <div class="text-right">
              <div class="text-[11px] eyebrow text-gulf-500">From</div>
              <div class="serif text-[22px] text-navy rate-cell">$145<span class="text-[12px] text-navy/50 ml-0.5 font-sans not-italic">/night</span></div>
            </div>
          </div>
          <p class="mt-3 text-[14.5px] leading-[1.75] text-navy/70">
            A spacious living room, a comfortable bedroom, a full bath, and a fully equipped kitchen. Choose poolside or gulf front — both walk straight onto the sand.
          </p>
          <ul class="mt-6 grid grid-cols-2 gap-x-5 gap-y-2.5 text-[13px] text-navy/75">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              Sleeps up to 4
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 0 4H2"/><path d="M2 12v8"/><path d="M22 20H2"/></svg>
              1 bedroom · full bath
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
              Full kitchen
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 9V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v10c0 1.1.9 2 2 2h2"/><path d="M5 19h14"/><path d="M5 22h14"/><path d="M16 15a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v4Z"/></svg>
              Living room
            </li>
          </ul>
          <div class="mt-7 flex items-center gap-3 flex-wrap">
            <a href="#rates" class="btn-primary inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-[13px] font-medium">
              See seasonal rates
              <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href="#book" class="btn-ghost inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-[13px] font-medium">
              Check dates
            </a>
          </div>
        </div>
      </article>

      <!-- 3BR Condo -->
      <article class="room-card bg-sand-50 rounded-2xl overflow-hidden border border-navy/[.06] shadow-card reveal">
        <div class="aspect-[16/10] overflow-hidden relative">
          <div class="room-img w-full h-full">
            <img src="/assets/photos/hero-beachfront.webp" alt="Great Heron Inn facade from the beach" class="w-full h-full object-cover" />
          </div>
          <span class="absolute top-4 left-4 px-2.5 py-1 rounded-full bg-sand-50/90 backdrop-blur text-[11px] eyebrow text-sunset-600">For larger groups</span>
        </div>
        <div class="p-8 md:p-10">
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <h3 class="serif text-[28px] text-navy">3-Bedroom Condo Apartment</h3>
            <div class="text-right">
              <div class="text-[11px] eyebrow text-gulf-500">Rates</div>
              <div class="serif text-[18px] text-navy">Please call</div>
            </div>
          </div>
          <p class="mt-3 text-[14.5px] leading-[1.75] text-navy/70">
            Our largest apartment — three bedrooms, two full baths, a fully equipped kitchen, a living room, and a dining room. The balcony looks out over the ocean on one side and the Inland Coastal Waterway on the other.
          </p>
          <ul class="mt-6 grid grid-cols-2 gap-x-5 gap-y-2.5 text-[13px] text-navy/75">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              Sleeps up to 6 adults
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 0 4H2"/><path d="M2 12v8"/><path d="M22 20H2"/></svg>
              3 bedrooms · 2 full baths
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
              Kitchen &amp; dining room
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              5–7 night minimum
            </li>
          </ul>
          <div class="mt-7 flex items-center gap-3 flex-wrap">
            <a href={`tel:${SITE.phoneTel}`} class="btn-primary inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-[13px] font-medium">
              <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.71 3.35a2 2 0 0 1 1.99-2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.36a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 15v1.92z"/></svg>
              Call for rates
            </a>
            <a href="#book" class="btn-ghost inline-flex items-center gap-2 px-4 py-2.5 rounded-full text-[13px] font-medium">
              Email an inquiry
            </a>
          </div>
        </div>
      </article>

    </div>
  </div>
</section>
