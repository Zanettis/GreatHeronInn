---
---

<section id="policies" class="relative py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-5 md:px-10">

    <div class="grid md:grid-cols-12 gap-10 mb-12 reveal">
      <div class="md:col-span-5">
        <div class="eyebrow text-sunset-500 mb-3">Policies &amp; Terms</div>
        <h2 class="text-[34px] md:text-[44px] leading-[1.05] text-navy">
          A few quiet rules,<br />
          <span class="italic font-light text-gulf-500">so everyone enjoys their stay.</span>
        </h2>
      </div>
      <div class="md:col-span-7">
        <p class="text-[15px] leading-[1.75] text-navy/70">
          The fine print, plainly. If anything's unclear, give us a call before you book and we'll happily talk it through.
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-navy/[.08] border border-navy/[.08] rounded-2xl overflow-hidden reveal">

      <div class="bg-sand-50 p-8">
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-5 h-5 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="21" cy="21" r="1"/><path d="M21 2H3v20"/><path d="M10 12h7"/></svg>
          <h3 class="serif text-[20px] text-navy">Check-in &amp; Check-out</h3>
        </div>
        <ul class="text-[14px] text-navy/75 leading-[1.8] space-y-1">
          <li>Check-in: <span class="text-navy">2:00 PM</span></li>
          <li>Check-out: <span class="text-navy">10:00 AM</span></li>
        </ul>
      </div>

      <div class="bg-sand-50 p-8">
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-5 h-5 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1-2-1Z"/><path d="M14 8H8"/><path d="M16 12H8"/><path d="M13 16H8"/></svg>
          <h3 class="serif text-[20px] text-navy">Occupancy &amp; Fees</h3>
        </div>
        <p class="text-[14px] text-navy/75 leading-[1.8]">
          Rates are for 1 or 2 persons. Extra persons $20.00/night each plus tax. Florida tax of 13% is not included in the base rate.
        </p>
      </div>

      <div class="bg-sand-50 p-8">
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-5 h-5 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17H5a2 2 0 0 1 0-4h.5A7.5 7.5 0 0 1 13 6.5"/><circle cx="13" cy="6" r="3"/><path d="M21 17H5.5A2.5 2.5 0 0 0 3 19.5V20a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-3z"/></svg>
          <h3 class="serif text-[20px] text-navy">Parking</h3>
        </div>
        <p class="text-[14px] text-navy/75 leading-[1.8]">
          Due to limited parking, only 1 vehicle is allowed per apartment.
        </p>
      </div>

      <div class="bg-sand-50 p-8">
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-5 h-5 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
          <h3 class="serif text-[20px] text-navy">Pets</h3>
        </div>
        <p class="text-[14px] text-navy/75 leading-[1.8]">
          Sorry — no pets allowed.
        </p>
      </div>

      <div class="bg-sand-50 p-8">
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-5 h-5 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          <h3 class="serif text-[20px] text-navy">Reservations &amp; Cancellation</h3>
        </div>
        <p class="text-[14px] text-navy/75 leading-[1.8]">
          A security deposit is required with reservation. No deposit refund if canceled less than 2 weeks prior to arrival. Balance due upon arrival. No refunds for early departure.
        </p>
      </div>

      <div class="bg-sand-50 p-8">
        <div class="flex items-center gap-3 mb-3">
          <svg class="w-5 h-5 text-sunset-500 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>
          <h3 class="serif text-[20px] text-navy">Minimum Stay</h3>
        </div>
        <p class="text-[14px] text-navy/75 leading-[1.8]">
          Minimum night stays may be required on weekends and holidays. The 3-Bedroom Condo has a 5- to 7-night minimum depending on season.
        </p>
      </div>

    </div>

    <p class="mt-8 text-[12.5px] text-navy/55 reveal">
      Prices and policies subject to change without notice. Monthly rates available upon request.
    </p>
  </div>
</section>
